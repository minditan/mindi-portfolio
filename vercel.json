{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/(.*).glb",
      "headers": [{ "key": "Content-Type", "value": "model/gltf-binary" }]
    },
    {
      "source": "/music/(.*).mp3",
      "headers": [{ "key": "Content-Type", "value": "audio/mpeg" }]
    }
  ]
}
